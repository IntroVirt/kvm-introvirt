+/* Attach for introspection */
+static int kvm_vm_ioctl_attach_vcpu(struct kvm *kvm, u32 id) {
+	struct kvm_vcpu* vcpu;
+	int r;
+
+	printk(KERN_DEBUG "IV-kvm_main: introspection attach to vcpu %d\n", id);
+	kvm_get_kvm(kvm);
+
+	r = -ESRCH;
+	vcpu = kvm_get_vcpu_by_id(kvm, id);
+	if(!vcpu) {
+		printk(KERN_ERR "IV-kvm_main: no vCPU found with ID %d\n", id);
+		goto out_err;
+	}
+
+	r = -EBUSY;
+	if (vcpu->introspection_mm) {
+		printk(KERN_ERR "IV-kvm_main: vCPU %d already has an attached introspection tool\n", id);
+		goto out_err;
+	}
+
+	r = create_vcpu_introvirt_fd(vcpu);
+	if(r < 0) {
+		printk(KERN_ERR "IV-kvm_main: failed to create introvirt fd for vCPU %d. Code: %d\n", id, r);
+		goto out_err;
+	}
+
+	vcpu->introspection_mm = current->mm;
+	printk(KERN_DEBUG "IV-kvm_main: introspection attached to vcpu %d successfully\n", id);
+	goto out;
+
+out_err:
+	kvm_put_kvm(kvm);
+out:
+	return r;
+}
