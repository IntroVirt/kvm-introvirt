+		if (len > sizeof(struct kvm_introspection_patch_ver)) {
+			r = -ETOOSMALL;
+			printk(KERN_ERR "IV-kvm_main: introspection patch version not set correctly. Too small.\n");
+			goto out;
+		}
+
+		r = -EFAULT;
+		if(!copy_to_user(argp, str, len)) {
+			printk(KERN_DEBUG "IV-kvm_main: returning introspection patch version %s\n", str);
+			r = 0;
+		} else {
+			printk(KERN_ERR "IV-kvm_main: failed to copy patch version string to user memory.\n");
+		}
+		break;
+	}
 	default:
 		return kvm_arch_dev_ioctl(filp, ioctl, arg);
 	}
Index: 6.17.0-14-generic/kernel/arch/x86/kvm/mmu/tdp_mmu.c
===================================================================
--- 6.17.0-14-generic.orig/kernel/arch/x86/kvm/mmu/tdp_mmu.c
+++ 6.17.0-14-generic/kernel/arch/x86/kvm/mmu/tdp_mmu.c
@@ -1991,3 +1991,128 @@ u64 *kvm_tdp_mmu_fast_pf_get_last_sptep(
 	 */
 	return rcu_dereference(sptep);
 }
+
+/* IntroVirt Patch */
+int kvm_tdp_set_pte_perms(struct kvm_vcpu *vcpu, u64 gfn, uint8_t perms, uint8_t* original_perms)
+{
+	struct kvm_mmu_page *root;
+	struct tdp_iter iter;
+	gfn_t gfn_bits;
+	u64 new_spte;
+	int result = -ESRCH;
+
+	printk(KERN_DEBUG "Setting permissions 0x%x on gfn 0x%08llx\n", perms, gfn);
+
+	// Turn off any extra bits in the perms
+	perms &= (PT_USER_MASK | PT_WRITABLE_MASK | PT_PRESENT_MASK);
+
+	// Validate the HAP permissions are allowed
+	if (unlikely(!kvm_x86_ops.hap_permissions_allowed(perms))) {
+		printk(KERN_ERR "IV-tdp_mmu: HAP permissions not allowed\n");
+		return -EINVAL;
+	}
+
+	// Ensure the MMU is loaded
+	if (!VALID_PAGE(vcpu->arch.mmu->root.hpa)) {
+		result = kvm_mmu_load(vcpu);
+		if (unlikely(result)) {
+			printk(KERN_ERR "IV-tdp_mmu: Failed to load MMU root host phys addr 0x%08llx. Code: %d\n", vcpu->arch.mmu->root.hpa, result);
+			return result;
+		}
+	}
+
+	// Get the TDP MMU root page
+	root = root_to_sp(vcpu->arch.mmu->root.hpa);
+	if (!root) {
+		printk(KERN_ERR "IV-tdp_mmu: Failed to get TDP MMU root for vCPU %d\n", vcpu->vcpu_id);
+		return -EINVAL;
+	}
+
+	gfn_bits = kvm_gfn_root_bits(vcpu->kvm, root);
+
+	// Must hold RCU lock for TDP MMU operations
+	rcu_read_lock();
+retry:
+	// Start iterator to walk to target guest frame number
+	tdp_iter_start(&iter, root, PG_LEVEL_4K, gfn, gfn_bits);
+
+	/* Walk to the target SPTE */
+	while (iter.valid && iter.gfn <= gfn) {
+		/* Check if we found the target 4K page */
+		if (iter.gfn == gfn && iter.level == PG_LEVEL_4K && is_last_spte(iter.old_spte, iter.level)) {
+			/* Found the target SPTE, modify it */
+			new_spte = (iter.old_spte &  ~(PT_USER_MASK | PT_WRITABLE_MASK | PT_PRESENT_MASK)) | perms;
+
+			if (original_perms != NULL) {
+				*original_perms = (iter.old_spte & (PT_USER_MASK | PT_WRITABLE_MASK | PT_PRESENT_MASK));
+			}
+
+			/* Atomically update the SPTE */
+			if (tdp_mmu_set_spte_atomic(vcpu->kvm, &iter, new_spte) != 0) {
+				printk(KERN_ERR "IV-tdp_mmu: could not update spte, trying again.\n");
+				continue;
+			}
+
+			/* Invalidate TLB if needed */
+			if (is_shadow_present_pte(iter.old_spte) && leaf_spte_change_needs_tlb_flush(iter.old_spte, new_spte)) {
+				printk(KERN_DEBUG "IV-tdp_mmu: TLB flush to update spte\n");
+				kvm_flush_remote_tlbs_gfn(vcpu->kvm, iter.gfn, iter.level);
+			}
+
+			result = 0;
+			break;
+		}
+
+		/* Page not present or not at 4K level - need to page it in */
+		if (!is_shadow_present_pte(iter.old_spte) || iter.level < PG_LEVEL_4K) {
+			rcu_read_unlock();
+			{
+				int r;
+				struct mm_struct *mm;
+
+				printk(KERN_DEBUG "IV-tdp_mmu: page for gfn 0x%08llx not present. Injecting page fault\n", gfn);
+				mm = current->mm;
+				current->mm = vcpu->kvm->mm;
+				r = __kvm_mmu_do_page_fault(vcpu, gfn << PAGE_SHIFT, 0, false, NULL, NULL, false);
+				current->mm = mm;
+				if (r != 0 && r != RET_PF_FIXED && r != RET_PF_SPURIOUS) {
+					printk(KERN_ERR "IV-mmu: Failed to page in gfn 0x%08llx. Code: %d\n", gfn, r);
+					return r;
+				}
+			}
+			rcu_read_lock();
+			goto retry;
+		}
+
+		/*
+		 * Present leaf at huge page level (2M or 1G): target gfn is inside
+		 * this range but we need a 4K SPTE. Split the huge page so the
+		 * next walk finds a 4K leaf.
+		 */
+		if (iter.level > PG_LEVEL_4K && is_last_spte(iter.old_spte, iter.level) && gfn >= iter.gfn && gfn < iter.gfn + KVM_PAGES_PER_HPAGE(iter.level)) {
+			printk(KERN_DEBUG "IV-mmu: Present leaf at huge page. Splitting and retrying\n");
+			struct kvm_memory_slot *slot;
+
+			rcu_read_unlock();
+			slot = kvm_vcpu_gfn_to_memslot(vcpu, gfn);
+			if (slot) {
+				write_lock(&vcpu->kvm->mmu_lock);
+				kvm_tdp_mmu_try_split_huge_pages(vcpu->kvm, slot,
+					iter.gfn, iter.gfn + KVM_PAGES_PER_HPAGE(iter.level),
+					PG_LEVEL_4K, false);
+				write_unlock(&vcpu->kvm->mmu_lock);
+			}
+			rcu_read_lock();
+			goto retry;
+		}
+
+		tdp_iter_next(&iter);
+	}
+	rcu_read_unlock();
+
+	if (result != 0 && iter.valid) {
+		printk(KERN_ERR "IV-mmu: Failed to find or modify SPTE for GFN 0x%08llx Code: %d\n", gfn, result);
+	}
+
+	return result;
+}
