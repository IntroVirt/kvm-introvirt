+			mutex_unlock(&vcpu->mutex);
+
+			/* Wait until we're resumed */
+			wait_event(vcpu->pause_wait_queue,
+				atomic_read(&vcpu->pause_count) == 0);
+
+			/* Retake the vcpu */
+			if (mutex_lock_killable(&vcpu->mutex))
